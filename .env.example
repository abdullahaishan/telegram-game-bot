# ═══════════════════════════════════════════════════════════════
# Telegram Multiplayer Game Platform - Configuration
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The system will NOT start without valid bot tokens.
# python-dotenv will auto-load this file if present.
#
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED: Bot Tokens ──────────────────────────────────────
# Get tokens from @BotFather on Telegram
GAME_BOT_TOKEN=YOUR_GAME_BOT_TOKEN_HERE
ADMIN_BOT_TOKEN=YOUR_ADMIN_BOT_TOKEN_HERE

# ── REQUIRED: Admin Telegram IDs ──────────────────────────────
# Comma-separated list of Telegram user IDs allowed to use Admin Bot
# Get your ID from @userinfobot on Telegram
ADMIN_IDS=123456789

# ── DEPLOYMENT (Render / Docker) ──────────────────────────────
# Health-check server port (Render sets PORT automatically)
PORT=10000

# Auto-restart on fatal errors (set to "false" to disable)
AUTO_RESTART=true

# Log rotation settings
LOG_MAX_BYTES=10485760     # 10 MB per log file
LOG_BACKUP_COUNT=5         # Keep 5 rotated backups

# ── WEBHOOK MODE (optional, not yet implemented) ──────────────
# Leave empty for polling mode (default, recommended for Render)
# Set to a URL for webhook mode (requires HTTPS endpoint)
# WEBHOOK_URL=https://your-app.onrender.com/webhook
